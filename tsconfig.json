{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "vitest/globals"],
    "baseUrl": "."
  },
  "include": ["agents/**/*.ts", "api/**/*.ts", "memory/**/*.ts", "server/**/*.ts", "tests/**/*.ts", "tools/**/*.ts"]
}
